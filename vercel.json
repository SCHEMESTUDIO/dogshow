{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/d/:slug", "destination": "/api/dog?slug=:slug" },
    { "source": "/breeds/:slug", "destination": "/api/breed?slug=:slug" },
    { "source": "/:slug", "destination": "/:slug.html" }
  ]
}
